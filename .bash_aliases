# --- timestamp utility
alias isosec='date +%Y%m%d%H%M%S'

# --- text editors
## emacs
alias emacs='emacs -nw'

# --- info
alias shell-count='ls /dev/pts/ | wc -l'

# --- clipboard

alias c='xclip'
alias v='xclip -o'

## system clipboard

alias cs='xclip -selection clipboard'
alias vs='xclip -o -selection clipboard'

